# Auto-generated - run make to regenerate
CompileFlags:
  Add: [-std=c99, -Wall, -I.]
  Compiler: gcc
---
If:
  PathMatch: arena\.c
CompileFlags:
  Add: []
---
If:
  PathMatch: game_engine\.c
CompileFlags:
  Add: [-include, SDL2/SDL_keycode.h, -include, SDL2/SDL_scancode.h, -include, game.h, -include, arena.c]
---
If:
  PathMatch: editor\.c
